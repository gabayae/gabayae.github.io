@article{kadurha2025bellman,
  bibtex_show = {true},
  title       = {Bellman Operator Convergence Enhancements in Reinforcement Learning Algorithms},
  author      = {Kadurha, David Krame and Moutouo, Domini Jocema Leko and Gaba, Ya{\'e} Ulrich},
  year        = {2025},
  eprint      = {2505.14564},
  archiveprefix = {arXiv},
  primaryclass  = {cs.LG},
  arxiv       = {2505.14564},
  abbr        = {arXiv},
  preview     = {bellman-rl.svg},
  selected    = {true},
  abstract    = {This paper reviews the topological groundwork for the study of reinforcement learning by focusing on the structure of state, action, and policy spaces, and illustrates how the Banach fixed-point theorem explains the convergence of RL algorithms. Alternative Bellman operator formulations are explored and tested on standard environments including MountainCar, CartPole, and Acrobot.}
}

@article{kadurha2024topological,
  bibtex_show = {true},
  title       = {Topological Foundations of Reinforcement Learning},
  author      = {Kadurha, David Krame and Gaba, Ya{\'e} Ulrich},
  year        = {2024},
  eprint      = {2410.03706},
  archiveprefix = {arXiv},
  primaryclass  = {cs.LG},
  arxiv       = {2410.03706},
  abbr        = {arXiv},
  preview     = {topo-rl.svg},
  selected    = {true},
  abstract    = {This work serves as a foundation for deep studies of the topology of state, action, and policy spaces in reinforcement learning. It connects the Banach fixed point theorem to RL algorithm convergence and demonstrates how mathematical insights from topology can inform more efficient RL algorithm design.}
}

@article{gaba2019quasiuniform,
  bibtex_show = {true},
  title       = {Quasi-uniform Type Spaces},
  author      = {Gaba, Ya{\'e} Ulrich},
  year        = {2019},
  eprint      = {1903.06582},
  archiveprefix = {arXiv},
  primaryclass  = {math.GN},
  arxiv       = {1903.06582},
  abbr        = {arXiv},
  preview     = {quasi-uniform.svg},
  abstract    = {We introduce the concept of partial quasi-metric type space as a generalization of both partial quasi-metric and quasi-metric type spaces. We show that topological and quasi-uniformity theories applicable to quasi-metric spaces extend to these generalized spaces, and prove that the Banach, Kannan, Reich and Chatterjea fixed point theorems can be successfully extended to this more general setting.}
}

@article{gaba2017eta,
  bibtex_show = {true},
  title       = {$\eta$-Metric Structures},
  author      = {Gaba, Ya{\'e} Ulrich},
  year        = {2017},
  eprint      = {1709.07690},
  archiveprefix = {arXiv},
  primaryclass  = {math.GN},
  arxiv       = {1709.07690},
  abbr        = {arXiv},
  preview     = {eta-metric.svg},
  abstract    = {We introduce the notion of $\eta$-cone metric spaces and explore their topological properties, proving fixed point theorems for contractive type maps on these spaces. These structures generalize both cone metric spaces and metric type spaces.}
}

