<!doctype html>
<html lang="en">
  <head>
    {% include head.liquid %}
    <style>
      body.landing-page {
        margin: 0;
        padding: 2rem 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: #0f1a33;
        position: relative;
        overflow-x: hidden;
        overflow-y: auto;
      }
      .landing-bg {
        position: fixed;
        inset: 0;
        background: url('{{ "/assets/img/yae--image.jpg" | relative_url }}') center top/cover no-repeat;
        filter: brightness(0.25) saturate(0.7) blur(3px);
        transform: scale(1.05);
        z-index: 0;
      }
      .landing-overlay {
        position: fixed;
        inset: 0;
        background: linear-gradient(
          160deg,
          rgba(15, 26, 51, 0.85) 0%,
          rgba(27, 42, 74, 0.7) 40%,
          rgba(212, 168, 67, 0.15) 100%
        );
        z-index: 1;
      }
      .landing-container {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 2.5rem;
        max-width: 700px;
      }
      .landing-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 3px solid rgba(212, 168, 67, 0.6);
        margin: 0 auto 1.5rem;
        object-fit: cover;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
      }
      .landing-name {
        font-family: "Roboto Slab", serif;
        font-size: 3rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 0.4rem;
        text-shadow: 0 2px 20px rgba(0,0,0,0.3);
        letter-spacing: 0.5px;
      }
      .landing-title {
        font-size: 1.15rem;
        color: rgba(232, 197, 109, 0.9);
        margin-bottom: 0.75rem;
        font-weight: 400;
        letter-spacing: 1px;
      }
      .landing-affiliations {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.55);
        margin-bottom: 2rem;
        line-height: 1.6;
      }
      .landing-affiliations a {
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        border-bottom: 1px dotted rgba(255,255,255,0.3);
      }
      .landing-affiliations a:hover {
        color: #e8c56d;
        border-bottom-color: #e8c56d;
      }
      .landing-divider {
        width: 60px;
        height: 3px;
        background: linear-gradient(90deg, transparent, #d4a843, transparent);
        margin: 0 auto 2rem;
        border: none;
      }
      .landing-label {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.6);
        margin-bottom: 1.5rem;
        font-weight: 300;
        letter-spacing: 0.5px;
      }
      .landing-buttons {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
      }
      .landing-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.9rem 2.5rem;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        min-width: 200px;
        justify-content: center;
        backdrop-filter: blur(8px);
      }
      .landing-btn-en {
        background: rgba(212, 168, 67, 0.9);
        color: #0f1a33;
        border: 2px solid #d4a843;
      }
      .landing-btn-en:hover {
        background: #e8c56d;
        border-color: #e8c56d;
        color: #0f1a33;
        text-decoration: none;
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(212, 168, 67, 0.35);
      }
      .landing-btn-fr {
        background: rgba(255, 255, 255, 0.08);
        color: #ffffff;
        border: 2px solid rgba(255, 255, 255, 0.3);
      }
      .landing-btn-fr:hover {
        background: rgba(255, 255, 255, 0.15);
        border-color: #e8c56d;
        color: #e8c56d;
        text-decoration: none;
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
      }
      .landing-flag {
        font-size: 1.4rem;
      }
      .landing-socials {
        margin-top: 2.5rem;
        display: flex;
        justify-content: center;
        gap: 1.25rem;
      }
      .landing-socials a {
        color: rgba(255, 255, 255, 0.4);
        font-size: 1.2rem;
        transition: color 0.2s ease, transform 0.2s ease;
        text-decoration: none;
      }
      .landing-socials a:hover {
        color: #e8c56d;
        transform: translateY(-2px);
      }
      @media (max-width: 576px) {
        .landing-name { font-size: 2.2rem; }
        .landing-btn { min-width: 170px; padding: 0.8rem 1.8rem; font-size: 1rem; }
        .landing-avatar { width: 90px; height: 90px; }
      }
    </style>
  </head>
  <body class="landing-page">
    <div class="landing-bg"></div>
    <div class="landing-overlay"></div>
    <div class="landing-container">
      <!-- Avatar removed — yae--image.jpg used as background -->
      <h1 class="landing-name">
        {% if site.title == 'blank' %}
          {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}
        {% else %}
          {{ site.title }}
        {% endif %}
      </h1>
      <p class="landing-title">{{ page.subtitle }}</p>
      <p class="landing-affiliations">
        <a href="https://github.com/AI-Technipreneurs" target="_blank">AIRINA Labs</a> ·
        <a href="https://acas-yde.org/" target="_blank">ACAS</a> ·
        Kigali, Rwanda
      </p>
      <div class="landing-divider"></div>
      <p class="landing-label">{{ page.choose_label | default: "Choose your language" }}</p>
      <div class="landing-buttons">
        <a href="{{ '/en/' | relative_url }}" class="landing-btn landing-btn-en">
          <span class="landing-flag">🇬🇧</span> English
        </a>
        <a href="{{ '/fr/' | relative_url }}" class="landing-btn landing-btn-fr">
          <span class="landing-flag">🇫🇷</span> Français
        </a>
      </div>
      <div class="landing-socials">
        <a href="https://scholar.google.com/citations?user=UTszjV4AAAAJ&hl=en" target="_blank" title="Google Scholar"><i class="fa-brands fa-google-scholar"></i></a>
        {% if site.data.socials.github_username %}
          <a href="https://github.com/{{ site.data.socials.github_username }}" target="_blank" title="GitHub"><i class="fa-brands fa-github"></i></a>
        {% endif %}
        {% if site.data.socials.orcid_id %}
          <a href="https://orcid.org/{{ site.data.socials.orcid_id }}" target="_blank" title="ORCID"><i class="fa-brands fa-orcid"></i></a>
        {% endif %}
        <a href="https://arxiv.org/a/gaba_y_1.html" target="_blank" title="arXiv"><i class="fa-solid fa-file-lines"></i></a>
        {% if site.data.socials.linkedin_username %}
          <a href="https://www.linkedin.com/in/{{ site.data.socials.linkedin_username }}" target="_blank" title="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
        {% endif %}
      </div>
    </div>
    {% include scripts.liquid %}
  </body>
</html>
