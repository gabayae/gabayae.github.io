% preamble.sty — Shared preamble for Linear Algebra course notes
% Used by both fr/cours.tex and en/notes.tex
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{preamble}[2026/02/28 Shared preamble for Linear Algebra notes]

% ============================================================
% Option handling: language
% ============================================================
\newif\if@french\@frenchfalse
\DeclareOption{french}{\@frenchtrue}
\DeclareOption{english}{\@frenchfalse}
\ProcessOptions\relax

% ============================================================
% Core packages
% ============================================================
\RequirePackage{amsmath,amssymb,amsthm}
\RequirePackage{mathtools}          % \coloneqq, \DeclarePairedDelimiter, etc.
\RequirePackage{mathrsfs}           % \mathscr
\RequirePackage{enumitem}           % customise lists
\RequirePackage{booktabs}           % professional tables
\RequirePackage{array}
\RequirePackage{longtable}          % multi-page tables
\RequirePackage{multicol}
\RequirePackage{fancyhdr}           % headers/footers
\RequirePackage{titlesec}           % chapter/section formatting
\RequirePackage{tocloft}            % TOC customisation
\RequirePackage{imakeidx}           % index
\RequirePackage{xcolor}
\RequirePackage{framed}             % coloured boxes
\RequirePackage{tcolorbox}
\tcbuselibrary{theorems,skins,breakable}
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta,calc,decorations.pathmorphing,patterns,positioning,
  matrix,3d,perspective,intersections,angles,quotes}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}
\RequirePackage{caption}
\RequirePackage{float}

% ============================================================
% Font setup (XeLaTeX)
% ============================================================
\RequirePackage{fontspec}
\RequirePackage{unicode-math}
\setmainfont{Latin Modern Roman}
\setmathfont{Latin Modern Math}

% ============================================================
% Language support (must be loaded BEFORE biblatex)
% ============================================================
\RequirePackage{polyglossia}
\if@french
  \setmainlanguage{french}
\else
  \setmainlanguage{english}
\fi

% ============================================================
% Bibliography (must come AFTER polyglossia)
% ============================================================
\RequirePackage[backend=biber,style=alphabetic,sorting=nyt]{biblatex}

% ============================================================
% Hyperlinks and cross-references
% ============================================================
\RequirePackage[
  colorlinks=true,
  linkcolor=blue!60!black,
  citecolor=green!50!black,
  urlcolor=blue!70!black
]{hyperref}
\RequirePackage[nameinlink,capitalize]{cleveref}

% ============================================================
% Colour palette
% ============================================================
\definecolor{defcolor}{RGB}{0,80,150}
\definecolor{thmcolor}{RGB}{150,30,30}
\definecolor{lemcolor}{RGB}{30,120,60}
\definecolor{remcolor}{RGB}{100,100,100}
\definecolor{excolor}{RGB}{180,100,0}
\definecolor{exocolor}{RGB}{80,0,130}

% ============================================================
% Theorem-like environments (tcolorbox)
% ============================================================
% Counter shared across all theorem-like environments, reset per chapter
\newcounter{thmcounter}[chapter]
\renewcommand{\thethmcounter}{\thechapter.\arabic{thmcounter}}

% --- Definition ---
\if@french
  \newtcbtheorem[use counter=thmcounter,crefname={définition}{définitions}]{definition}{Définition}{%
    colback=defcolor!5,colframe=defcolor!80,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{def}
\else
  \newtcbtheorem[use counter=thmcounter,crefname={Definition}{Definitions}]{definition}{Definition}{%
    colback=defcolor!5,colframe=defcolor!80,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{def}
\fi

% --- Theorem ---
\if@french
  \newtcbtheorem[use counter=thmcounter,crefname={théorème}{théorèmes}]{theorem}{Théorème}{%
    colback=thmcolor!5,colframe=thmcolor!80,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{thm}
\else
  \newtcbtheorem[use counter=thmcounter,crefname={Theorem}{Theorems}]{theorem}{Theorem}{%
    colback=thmcolor!5,colframe=thmcolor!80,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{thm}
\fi

% --- Proposition ---
\if@french
  \newtcbtheorem[use counter=thmcounter,crefname={proposition}{propositions}]{proposition}{Proposition}{%
    colback=thmcolor!5!white,colframe=thmcolor!50,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{prop}
\else
  \newtcbtheorem[use counter=thmcounter,crefname={Proposition}{Propositions}]{proposition}{Proposition}{%
    colback=thmcolor!5!white,colframe=thmcolor!50,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{prop}
\fi

% --- Lemma ---
\if@french
  \newtcbtheorem[use counter=thmcounter,crefname={lemme}{lemmes}]{lemma}{Lemme}{%
    colback=lemcolor!5,colframe=lemcolor!70,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{lem}
\else
  \newtcbtheorem[use counter=thmcounter,crefname={Lemma}{Lemmas}]{lemma}{Lemma}{%
    colback=lemcolor!5,colframe=lemcolor!70,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{lem}
\fi

% --- Corollary ---
\if@french
  \newtcbtheorem[use counter=thmcounter,crefname={corollaire}{corollaires}]{corollary}{Corollaire}{%
    colback=thmcolor!3,colframe=thmcolor!40,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{cor}
\else
  \newtcbtheorem[use counter=thmcounter,crefname={Corollary}{Corollaries}]{corollary}{Corollary}{%
    colback=thmcolor!3,colframe=thmcolor!40,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{cor}
\fi

% --- Example ---
\if@french
  \newtcbtheorem[use counter=thmcounter,crefname={exemple}{exemples}]{example}{Exemple}{%
    colback=excolor!5,colframe=excolor!70,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{ex}
\else
  \newtcbtheorem[use counter=thmcounter,crefname={Example}{Examples}]{example}{Example}{%
    colback=excolor!5,colframe=excolor!70,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{ex}
\fi

% --- Remark ---
\if@french
  \newtcbtheorem[use counter=thmcounter,crefname={remarque}{remarques}]{remark}{Remarque}{%
    colback=remcolor!5,colframe=remcolor!40,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{rem}
\else
  \newtcbtheorem[use counter=thmcounter,crefname={Remark}{Remarks}]{remark}{Remark}{%
    colback=remcolor!5,colframe=remcolor!40,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{rem}
\fi

% --- Exercise ---
\if@french
  \newtcbtheorem[use counter=thmcounter,crefname={exercice}{exercices}]{exercise}{Exercice}{%
    colback=exocolor!3,colframe=exocolor!50,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{exo}
\else
  \newtcbtheorem[use counter=thmcounter,crefname={Exercise}{Exercises}]{exercise}{Exercise}{%
    colback=exocolor!3,colframe=exocolor!50,fonttitle=\bfseries,
    separator sign none,description delimiters parenthesis,
    breakable,enhanced}{exo}
\fi

% --- Proof environment override ---
\if@french
  \renewcommand{\proofname}{Démonstration}
\fi

% ============================================================
% Mathematical notation macros
% ============================================================

% --- Fields ---
\newcommand{\K}{{\mathbb{K}}}         % generic field (braced for subscripts)
\newcommand{\R}{{\mathbb{R}}}         % real numbers
\newcommand{\C}{{\mathbb{C}}}         % complex numbers
\newcommand{\Q}{{\mathbb{Q}}}         % rationals
\newcommand{\Z}{{\mathbb{Z}}}         % integers
\newcommand{\N}{{\mathbb{N}}}         % naturals
\newcommand{\F}{{\mathbb{F}}}         % finite field

% --- Vector spaces & linear algebra ---
\newcommand{\Vect}{\operatorname{Vect}}     % span (French style)
\DeclareMathOperator{\Span}{Span}            % span (English style)
\DeclareMathOperator{\rg}{rg}               % rank (French: rang)
\DeclareMathOperator{\rank}{rank}           % rank (English)
\DeclareMathOperator{\im}{Im}              % image
\DeclareMathOperator{\Ker}{Ker}            % kernel
\DeclareMathOperator{\coker}{coker}        % cokernel
\DeclareMathOperator{\Id}{Id}              % identity map
\DeclareMathOperator{\End}{End}            % endomorphisms
\DeclareMathOperator{\Hom}{Hom}            % homomorphisms
\DeclareMathOperator{\Aut}{Aut}            % automorphisms
\DeclareMathOperator{\GL}{GL}              % general linear group
\DeclareMathOperator{\SL}{SL}              % special linear group
\DeclareMathOperator{\Orth}{O}             % orthogonal group
\DeclareMathOperator{\SO}{SO}              % special orthogonal group
\DeclareMathOperator{\Sym}{Sym}            % symmetric group / matrices
\DeclareMathOperator{\tr}{tr}              % trace
\DeclareMathOperator{\diag}{diag}          % diagonal
\DeclareMathOperator{\sgn}{sgn}            % sign of permutation
\DeclareMathOperator{\car}{car}            % characteristic (French)
\DeclareMathOperator{\Char}{char}          % characteristic (English)
\DeclareMathOperator{\Spec}{Spec}          % spectrum
\DeclareMathOperator{\proj}{proj}          % projection
\DeclareMathOperator{\argmin}{argmin}
\DeclareMathOperator{\pgcd}{pgcd}         % gcd in French

% --- Matrices ---
\newcommand{\Mat}{\mathcal{M}}             % matrix space
\newcommand{\GL@n}[1]{\GL_{#1}(\K)}       % GL_n(K)
\newcommand{\transpose}[1]{{#1}^{\mathsf{T}}}  % transpose
\newcommand{\hermit}[1]{{#1}^{*}}         % conjugate transpose
\newcommand{\inv}[1]{{#1}^{-1}}           % inverse

% --- Inner products and norms ---
\DeclarePairedDelimiter{\abs}{\lvert}{\rvert}
\DeclarePairedDelimiter{\norm}{\lVert}{\rVert}
\DeclarePairedDelimiter{\inner}{\langle}{\rangle}
\DeclarePairedDelimiter{\floor}{\lfloor}{\rfloor}
\DeclarePairedDelimiter{\ceil}{\lceil}{\rceil}

% --- Set notation ---
\newcommand{\set}[1]{\left\{#1\right\}}
\newcommand{\setcond}[2]{\left\{\,#1\;\middle|\;#2\,\right\}}
\newcommand{\card}[1]{\left|#1\right|}

% --- Vectors (bold) ---
\renewcommand{\vec}[1]{\mathbf{#1}}
\newcommand{\vece}[1]{\vec{e}_{#1}}       % basis vector e_i
\newcommand{\vecf}[1]{\vec{f}_{#1}}       % basis vector f_i
\newcommand{\vzero}{\vec{0}}              % zero vector

% --- Calligraphic letters for families, bases (braced for subscripts) ---
\newcommand{\cB}{{\mathcal{B}}}           % basis
\newcommand{\cC}{{\mathcal{C}}}           % basis
\newcommand{\cE}{{\mathcal{E}}}           % canonical basis
\newcommand{\cF}{{\mathcal{F}}}           % family
\newcommand{\cL}{{\mathcal{L}}}           % space of linear maps
\newcommand{\cP}{{\mathcal{P}}}           % polynomial space
\newcommand{\cS}{{\mathcal{S}}}           % solution set
\newcommand{\cD}{{\mathcal{D}}}           % basis
\DeclareMathOperator{\codim}{codim}       % codimension

% --- French quote commands (fallback if not defined by polyglossia) ---
\providecommand{\og}{«\,}
\providecommand{\fg}{\,»}

% --- Misc ---
\newcommand{\deff}{\coloneqq}             % definition equality
\newcommand{\eps}{\varepsilon}
\newcommand{\vphi}{\varphi}
\newcommand{\xto}[1]{\xrightarrow{#1}}   % labelled arrow
\newcommand{\isoto}{\xrightarrow{\sim}}   % isomorphism arrow
\newcommand{\restrict}[1]{{|_{#1}}}       % restriction

% Difficulty stars for exercises
\newcommand{\basic}{\textcolor{exocolor}{\symbol{"2605}}}
\newcommand{\intermediate}{\textcolor{exocolor}{\symbol{"2605}\symbol{"2605}}}
\newcommand{\challenging}{\textcolor{exocolor}{\symbol{"2605}\symbol{"2605}\symbol{"2605}}}

% ============================================================
% Page layout
% ============================================================
\RequirePackage[
  top=2.5cm, bottom=2.5cm, left=2.5cm, right=2.5cm,
  headheight=14pt
]{geometry}

% Header/footer
\pagestyle{fancy}
\fancyhf{}
\if@french
  \fancyhead[LE]{\textit{Algèbre Linéaire}}
  \fancyhead[RO]{\textit{\nouppercase{\rightmark}}}
\else
  \fancyhead[LE]{\textit{Linear Algebra}}
  \fancyhead[RO]{\textit{\nouppercase{\rightmark}}}
\fi
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0.4pt}

% Chapter title format
\titleformat{\chapter}[display]
  {\normalfont\huge\bfseries}
  {\chaptertitlename\ \thechapter}{20pt}{\Huge}

% ============================================================
% Index
% ============================================================
\makeindex[intoc]

% ============================================================
% Cref names (language-dependent)
% ============================================================
\if@french
  \crefname{chapter}{chapitre}{chapitres}
  \crefname{section}{section}{sections}
  \crefname{equation}{équation}{équations}
  \crefname{figure}{figure}{figures}
  \crefname{table}{tableau}{tableaux}
\fi

\endinput
