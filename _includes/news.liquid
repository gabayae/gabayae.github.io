<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% assign lang = page.lang | default: "en" %}
        {% for item in news limit: news_limit %}
          {% if item.lang and item.lang != lang %}{% continue %}{% endif %}
          {% assign month_en = item.date | date: '%b' %}
          {% assign day = item.date | date: '%d' %}
          {% assign year = item.date | date: '%Y' %}
          {% assign month_key = "months." | append: month_en %}
          {% assign t = site.data.translations[lang] %}
          {% if t and t.months and t.months[month_en] %}
            {% assign month_display = t.months[month_en] %}
          {% else %}
            {% assign month_display = month_en %}
          {% endif %}
          {% if lang == "fr" %}
            {% assign date_display = day | append: " " | append: month_display | append: " " | append: year %}
          {% else %}
            {% assign date_display = month_display | append: " " | append: day | append: ", " | append: year %}
          {% endif %}
          <tr>
            <th scope="row" style="width: 20%">{{ date_display }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    {% assign lang = page.lang | default: "en" %}
    {% assign t = site.data.translations[lang] %}
    {% if t and t.no_news %}
      <p>{{ t.no_news }}</p>
    {% else %}
      <p>No news so far...</p>
    {% endif %}
  {% endif %}
</div>
